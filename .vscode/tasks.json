{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "New Blog Post",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/new-post.sh",
      "args": [
        "${input:postSlug}"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "never",
        "panel": "shared",
        "clear": true,
        "close": true
      }
    },
    {
      "label": "Preview Blog",
      "type": "shell",
      "command": "hugo",
      "args": [
        "server",
        "--config",
        "hugo.toml,hugo.dev.toml"
      ],
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Build Blog",
      "type": "shell",
      "command": "hugo",
      "args": [
        "--config",
        "hugo.toml"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "never",
        "panel": "shared",
        "clear": true,
        "close": true
      }
    },
    {
      "label": "Add Asset To Post",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/add-asset.sh",
      "args": [
        "${input:assetPostSlug}",
        "${input:assetSourcePath}"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "never",
        "panel": "shared",
        "clear": true,
        "close": true
      }
    }
  ],
  "inputs": [
    {
      "id": "postSlug",
      "type": "promptString",
      "description": "New blog post folder name, for example: ai-tool-workflow"
    },
    {
      "id": "assetPostSlug",
      "type": "promptString",
      "description": "Target blog post folder name, for example: ai-tool-workflow"
    },
    {
      "id": "assetSourcePath",
      "type": "promptString",
      "description": "Absolute path of the local file to copy into this post's assets folder"
    }
  ]
}
